# Git history — never needed in a Docker build
.git
.gitignore

# Python artifacts
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist/
build/
.eggs/

# Virtual environments
.venv
venv/
env/

# Airflow runtime directories (large, not needed at build time)
airflow/logs/
data/

# Test output
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Secrets — should never be in a Docker image
.env
*.pem
*.key
